# Trading Bot Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!
#
# ============================================================================
# SECURITY HARDENING (March 2026 Audit)
# ============================================================================
# IMPORTANT: Sensitive keys are now stored in .encrypted_keys file
# Use secure_key_loader.py to manage encrypted keys
#
# To change encryption password:
#   python secure_key_loader.py set-password
#
# ============================================================================

# ============================================
# ENCRYPTION PASSWORD
# ============================================
# Set this for non-interactive mode (e.g., cron jobs)
# RECOMMEND: Use prompt mode instead for better security
ENCRYPTION_PASSWORD=

# ============================================
# API KEY SECURITY WARNINGS (CRITICAL)
# ============================================
# 
# EXCHANGE API KEYS - Use least-privilege permissions:
# - Binance: Enable ONLY "Spot Trading" - DISABLE withdrawals
# - Coinbase: Enable "Trade" only - DISABLE API trading and withdrawals
# - Kraken: Use "Trade" permission only
# - Bybit: Enable "Spot Trade" only - DISABLE "Withdrawal"
# - KuCoin: Enable "Trade" only
#
# IP WHITELISTING: Configure IP restrictions on exchange API keys
# to your device's IP address for additional security
#
# ROTATION: Rotate keys every 30-90 days
#
# ============================================

# Binance - RESTRICTED permissions only!
BINANCE_API_KEY=pItCby7H6HSh83T6UQkwYqCArysjZ5JQLmwpzYnhXMfZKON1ImWb8Z5Eag8fY6yI
BINANCE_SECRET=BITVYPiS3KQ6tWU1XtI6BFkbRrX2P27py3ltCpgiLEqKu8oC5SULhRRM5JulkZUb

# Coinbase - Trade-only permissions
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_SECRET=your_coinbase_secret_here

# Kraken - Trade-only permissions
KRAKEN_API_KEY=groor54uZ1rM0K/b3obX/l+SpLQ1gnKPGAkAmLC4bFxOzv+LEyNSo2m8
